<%- include('partials/header', { title: 'Marketplace', active: 'marketplace' }) %>

<div class="dash-header">
  <div class="container">
    <h1>Medical Supply Marketplace</h1>
    <p>Browse verified surplus supplies available for NGOs and free clinics</p>
  </div>
</div>

<section class="section-sm">
  <div class="container">

    <!-- Filter Bar -->
    <form method="GET" action="/marketplace" class="filter-bar">
      <input type="text" name="search" class="form-control search-input" placeholder="🔍  Search supplies, equipment, medication..." value="<%= query.search || '' %>">
      <select name="category" class="form-control" style="min-width:160px;">
        <option value="all">All Categories</option>
        <% categories.forEach(cat => { %>
        <option value="<%= cat %>" <%= query.category === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>
      <select name="status" class="form-control" style="min-width:140px;">
        <option value="all">All Status</option>
        <option value="available" <%= query.status === 'available' ? 'selected' : '' %>>Available</option>
        <option value="claimed" <%= query.status === 'claimed' ? 'selected' : '' %>>Claimed</option>
      </select>
      <button type="submit" class="btn btn-primary">Filter</button>
      <a href="/marketplace" class="btn btn-secondary">Clear</a>
    </form>

    <!-- Results Count -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
      <p style="font-size:0.9rem;"><strong style="color:var(--navy);"><%= listings.length %></strong> items found</p>
      <a href="/donate" class="btn btn-outline btn-sm">+ List New Supply</a>
    </div>

    <% if (listings.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📦</div>
      <h3>No supplies found</h3>
      <p>Try adjusting your filters or <a href="/marketplace">clear all filters</a>.</p>
    </div>
    <% } else { %>
    <div class="grid-3">
      <% listings.forEach(listing => { %>
      <div class="card listing-card">
        <div class="listing-img">
          <%= listing.category === 'Medication' ? '💊' : listing.category === 'Equipment' ? '🩺' : listing.category === 'PPE' ? '🧤' : '🏥' %>
        </div>
        <div class="card-body">
          <div class="listing-meta">
            <span class="badge badge-<%= listing.status %>">
              <%= listing.status === 'available' ? '✓ Available' : '✔ Claimed' %>
            </span>
            <span class="badge badge-<%= listing.category.toLowerCase().replace(' ','') %>"><%= listing.category %></span>
            <% if (listing.urgency === 'high') { %>
            <span class="badge badge-high">⚡ Urgent</span>
            <% } %>
          </div>
          <div class="listing-title"><%= listing.title %></div>
          <p style="font-size:0.85rem;color:var(--muted);margin-bottom:12px;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= listing.description %></p>
          <div class="listing-detail">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= listing.location %>
          </div>
          <div class="listing-detail">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            From: <strong style="color:var(--slate)"><%= listing.donor %></strong>
          </div>
          <div class="listing-detail">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Qty: <strong style="color:var(--slate)"><%= listing.quantity %></strong>
          </div>
          <% if (listing.expiry) { %>
          <div class="listing-detail">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            Expires: <%= new Date(listing.expiry).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'}) %>
          </div>
          <% } %>
        </div>
        <div class="card-footer">
          <a href="/listing/<%= listing.id %>" class="btn btn-<%= listing.status === 'available' ? 'primary' : 'secondary' %> btn-sm btn-full">
            <%= listing.status === 'available' ? 'View & Claim →' : 'View Details' %>
          </a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
