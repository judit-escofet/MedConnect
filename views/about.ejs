<%- include('partials/header', { title: 'About', active: 'about' }) %>

<!-- Hero -->
<section style="background:var(--navy);padding:80px 0;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;top:-100px;left:50%;transform:translateX(-50%);width:600px;height:400px;background:radial-gradient(circle,rgba(0,200,150,0.12) 0%,transparent 70%);pointer-events:none;"></div>
  <div class="container">
    <div class="hero-tag" style="margin:0 auto 24px;display:inline-flex;">🌍 Our Mission</div>
    <h1 style="color:white;max-width:700px;margin:0 auto 20px;">No medical supply should ever go to waste</h1>
    <p style="color:rgba(255,255,255,0.6);font-size:1.1rem;max-width:580px;margin:0 auto;">MedConnect bridges the gap between medical surplus and critical need — directly supporting SDG 3.8 and universal health coverage.</p>
  </div>
</section>

<!-- The Problem -->
<section class="section" style="background:white;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;">
      <div>
        <div class="section-label">The Problem</div>
        <h2>Billions in medical supplies wasted every year</h2>
        <p style="margin-top:16px;line-height:1.8;">Hospitals and pharmacies routinely discard perfectly good medical supplies — excess inventory, overstock from discontinued procedures, or items approaching expiry. At the same time, free clinics and NGOs desperately lack the most basic supplies to care for vulnerable patients.</p>
        <p style="margin-top:12px;line-height:1.8;">This isn't a supply problem. It's a distribution problem.</p>
        <div class="grid-2" style="margin-top:32px;gap:16px;">
          <div style="padding:20px;background:var(--light);border-radius:var(--r-md);">
            <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--coral);">$765M</div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:4px;">in medical waste annually in US hospitals alone</div>
          </div>
          <div style="padding:20px;background:var(--mint-light);border-radius:var(--r-md);">
            <div style="font-family:'DM Serif Display',serif;font-size:2rem;color:var(--teal);">1 in 4</div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:4px;">free clinics report critical supply shortages monthly</div>
          </div>
        </div>
      </div>
      <div style="background:var(--mint-light);border-radius:var(--r-xl);padding:48px;text-align:center;border:1px solid var(--mint-mid);">
        <div style="font-size:5rem;margin-bottom:20px;">🔄</div>
        <h3 style="margin-bottom:12px;">The MedConnect Solution</h3>
        <p style="font-size:0.95rem;line-height:1.7;">A zero-friction B2B marketplace connecting medical surplus directly to verified NGOs — at no cost, with full traceability.</p>
      </div>
    </div>
  </div>
</section>

<!-- SDG Alignment -->
<section class="section" style="background:var(--light);">
  <div class="container">
    <div class="section-header text-center" style="max-width:600px;margin-left:auto;margin-right:auto;">
      <div class="section-label">SDG Alignment</div>
      <h2>Built for SDG 3.8</h2>
      <p>Achieve universal health coverage, including access to safe, effective, quality, and affordable essential medicines and vaccines for all.</p>
    </div>
    <div class="grid-3">
      <div style="padding:28px;background:white;border-radius:var(--r-lg);border:1px solid var(--border);">
        <div style="font-size:2.5rem;margin-bottom:16px;">💊</div>
        <h4 style="margin-bottom:10px;">Essential Medicines Access</h4>
        <p style="font-size:0.875rem;line-height:1.7;">Redirects pharmaceuticals to communities that cannot afford them, ensuring essential medications reach patients regardless of economic status.</p>
      </div>
      <div style="padding:28px;background:white;border-radius:var(--r-lg);border:1px solid var(--border);">
        <div style="font-size:2.5rem;margin-bottom:16px;">🏥</div>
        <h4 style="margin-bottom:10px;">Strengthening Health Systems</h4>
        <p style="font-size:0.875rem;line-height:1.7;">Supports underfunded free clinics and NGOs with the equipment they need to operate effectively and serve more patients.</p>
      </div>
      <div style="padding:28px;background:white;border-radius:var(--r-lg);border:1px solid var(--border);">
        <div style="font-size:2.5rem;margin-bottom:16px;">🌱</div>
        <h4 style="margin-bottom:10px;">Reducing Medical Waste</h4>
        <p style="font-size:0.875rem;line-height:1.7;">Every item diverted from landfill reduces environmental impact while simultaneously serving a human health need.</p>
      </div>
    </div>
  </div>
</section>

<!-- Who We Serve -->
<section class="section" style="background:white;">
  <div class="container">
    <div class="section-header text-center">
      <div class="section-label">Who We Serve</div>
      <h2>A network built on trust</h2>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="card-body" style="padding:36px;">
          <div style="font-size:3rem;margin-bottom:16px;">🏥</div>
          <h3 style="margin-bottom:12px;">Donors</h3>
          <p style="line-height:1.8;margin-bottom:20px;">Hospitals, clinics, pharmacies, and individuals with surplus supplies. MedConnect provides an easy, verified channel to ensure supplies reach those who need them — with tax documentation where applicable.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Hospitals & health systems</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Independent pharmacies</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Private clinics</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Individual donors</li>
          </ul>
        </div>
      </div>
      <div class="card" style="border-color:var(--mint-mid);">
        <div class="card-body" style="padding:36px;">
          <div style="font-size:3rem;margin-bottom:16px;">🤲</div>
          <h3 style="margin-bottom:12px;">Recipients</h3>
          <p style="line-height:1.8;margin-bottom:20px;">Verified NGOs and free clinics serving underserved communities. We verify all recipients before they can claim supplies, ensuring items reach legitimate health organizations.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Free & charitable clinics</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Health-focused NGOs</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Community health centers</li>
            <li style="font-size:0.875rem;display:flex;gap:8px;align-items:flex-start;"><span style="color:var(--mint);font-weight:700;">✓</span> Disaster relief organizations</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background:var(--navy);text-align:center;">
  <div class="container">
    <h2 style="color:white;margin-bottom:14px;">Join the network</h2>
    <p style="color:rgba(255,255,255,0.55);margin-bottom:36px;max-width:460px;margin-left:auto;margin-right:auto;">Whether you're donating surplus or serving patients in need, MedConnect makes the connection simple.</p>
    <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
      <a href="/donate" class="btn btn-primary btn-lg">Donate Supplies</a>
      <a href="/marketplace" class="btn btn-outline btn-lg" style="color:rgba(255,255,255,0.8);border-color:rgba(255,255,255,0.3);">Browse Marketplace</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
